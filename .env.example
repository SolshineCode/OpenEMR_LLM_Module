# OpenEMR LLM Module Configuration
# Copy this file to .env and configure for your environment

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Flask server settings
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false
FLASK_SECRET_KEY=your-secret-key-change-in-production

# CORS settings (comma-separated origins)
CORS_ORIGINS=http://localhost,http://127.0.0.1

# Rate limiting
RATE_LIMIT_DEFAULT=100/hour
RATE_LIMIT_GENERATE=30/minute

# =============================================================================
# LLM BACKEND CONFIGURATION
# =============================================================================

# Backend type: "llamacpp", "ollama", "openai", "huggingface"
LLM_BACKEND=llamacpp

# --- llama.cpp Server Configuration ---
# URL of the llama.cpp server (run with: llama-server -m model.gguf --port 8080)
LLAMACPP_SERVER_URL=http://localhost:8080
LLAMACPP_API_KEY=

# --- Ollama Configuration ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest

# --- OpenAI-Compatible API Configuration ---
# Works with llama.cpp server, vLLM, LocalAI, etc.
OPENAI_API_BASE=http://localhost:8080/v1
OPENAI_API_KEY=
OPENAI_MODEL=local-model

# --- HuggingFace Configuration ---
HUGGINGFACE_MODEL=microsoft/BioGPT
HUGGINGFACE_CACHE_DIR=~/.cache/huggingface
HUGGINGFACE_DEVICE=auto
HUGGINGFACE_LOAD_IN_8BIT=false
HUGGINGFACE_LOAD_IN_4BIT=false

# =============================================================================
# MODEL INFERENCE PARAMETERS
# =============================================================================

# Generation parameters
MAX_TOKENS=512
TEMPERATURE=0.7
TOP_P=0.9
TOP_K=40
REPEAT_PENALTY=1.1

# Context window
CONTEXT_LENGTH=4096

# System prompt for medical assistant
SYSTEM_PROMPT=You are a helpful medical assistant integrated with OpenEMR. Provide accurate, evidence-based information while being clear that you are an AI assistant and not a replacement for professional medical advice. Always recommend consulting with healthcare providers for medical decisions.

# =============================================================================
# OPENEMR INTEGRATION
# =============================================================================

# OpenEMR API configuration
OPENEMR_BASE_URL=https://localhost:9300
OPENEMR_API_PATH=/apis/default/api
OPENEMR_FHIR_PATH=/apis/default/fhir

# OAuth2 client credentials (register in OpenEMR Admin)
OPENEMR_CLIENT_ID=
OPENEMR_CLIENT_SECRET=
OPENEMR_REDIRECT_URI=http://localhost:5000/oauth/callback

# Scopes for patient data access
OPENEMR_SCOPES=openid user/Patient.rs user/Encounter.rs user/Observation.rs user/Condition.rs user/AllergyIntolerance.rs user/MedicationRequest.rs

# SSL verification (set to false for self-signed certs in dev)
OPENEMR_VERIFY_SSL=true

# =============================================================================
# SECURITY & LOGGING
# =============================================================================

# Audit logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_FILE=logs/audit.log
AUDIT_LOG_LEVEL=INFO

# Application logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_FORMAT=json

# Data anonymization for prompts (strip PHI before sending to model)
ANONYMIZE_PATIENT_DATA=true

# Session timeout (seconds)
SESSION_TIMEOUT=3600

# =============================================================================
# FINE-TUNING (Unsloth)
# =============================================================================

# Path to fine-tuned model adapters
FINETUNED_ADAPTER_PATH=./models/medical_adapter
USE_FINETUNED_MODEL=false
